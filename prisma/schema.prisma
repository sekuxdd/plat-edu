generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @db.NVarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Chapter {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topics      Topic[]
}

model Topic {
  id          String    @id @default(cuid())
  chapterId   String
  title       String
  description String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chapter     Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  materials   Material[]
  tests       Test[]

  @@index([chapterId])
}

model Material {
  id          String   @id @default(cuid())
  topicId     String
  title       String
  type        String
  content     String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model Test {
  id            String   @id @default(cuid())
  topicId       String
  title         String
  questionCount Int
  answerMode    String   @default("text")
  status        String
  content       String
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}